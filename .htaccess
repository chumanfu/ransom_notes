<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /

    # When document root is project root (e.g. IONOS "Public folder path" = /public): serve assets from public/
    RewriteRule ^build/(.*)$ public/build/$1 [L]
    RewriteRule ^(favicon\.ico|robots\.txt)$ public/$1 [L]

    # Everything else that isn't a real file/dir goes to Laravel
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteRule ^ index.php [L]
</IfModule>
